#![enable(implicit_some)]
#![enable(unwrap_newtypes)]
#![enable(unwrap_variant_newtypes)]
(
    draw_borders: false,
    show_song_table_header: true,

    background_color:        "#101418",
    header_background_color: "#101418",
    modal_background_color:  "#17212e",
    modal_backdrop:          true,
    text_color:              "#e0e2e8",
    default_album_art_path:  None,

    format_tag_separator: " ◆ ",
    multiple_tag_resolution_strategy: Last,

    preview_label_style:          (fg: "#7afcff", modifiers: "Bold"),
    preview_metadata_group_style: (fg: "#ff3270", modifiers: "Bold"),

    level_styles: (
        info:  (fg: "#7afcff", bg: "#101418"),
        warn:  (fg: "#ff9ecb", bg: "#101418"),
        error: (fg: "#ff3270", bg: "#101418"),
        debug: (fg: "#8f6cf5", bg: "#101418"),
        trace: (fg: "#465577", bg: "#101418"),
    ),

    cava: (
        bar_width: 2,
        bar_spacing: 1,
        orientation: Bottom,
        bar_color: Gradient({
            0:   "#1b2a4a",
            14:  "#465577",
            28:  "#8f6cf5",
            42:  "#ff3270",
            56:  "#ff739e",
            70:  "#ff9ecb",
            85:  "#7afcff",
            100: "#42a5f5",
        }),
    ),

    lyrics: (timestamp: false),

    components: {
        "state": Pane(Property(
            content: [
                (kind: Text("「"), style: (fg: "#ff3270", modifiers: "Bold")),
                (kind: Property(Status(StateV2(
                    playing_label: "▶ PLAY ",
                    paused_label:  "❚❚ PAUSE",
                    stopped_label: "■ STOP ",
                ))), style: (fg: "#ff739e", modifiers: "Bold")),
                (kind: Text("」"), style: (fg: "#ff3270", modifiers: "Bold")),
            ],
            align: Left,
        )),

        "title": Pane(Property(
            content: [
                (kind: Property(Song(Title)),
                 style: (fg: "#7afcff", modifiers: "Bold"),
                 default: (kind: Text("⌖  N O   S I G N A L  ⌖"),
                           style: (fg: "#8f6cf5", modifiers: "Bold"))),
            ],
            align: Center,
            scroll_speed: 1,
        )),

        "volume": Split(
            direction: Horizontal,
            panes: [
                (size: "100%", pane: Pane(Property(
                    content: [(kind: Property(Widget(Volume)), style: (fg: "#7afcff"))],
                    align: Right,
                ))),
                (size: "3", pane: Pane(Property(
                    content: [(kind: Property(Status(Volume)),
                               style: (fg: "#7afcff", modifiers: "Bold"))],
                    align: Right,
                ))),
                (size: "1", pane: Pane(Property(
                    content: [(kind: Text("%"), style: (fg: "#7afcff"))],
                ))),
            ],
        ),

        "artist_album": Pane(Property(
            content: [
                (kind: Property(Song(Artist)),
                 style: (fg: "#ff3270", modifiers: "Bold"),
                 default: (kind: Text("Unknown Artist"),
                           style: (fg: "#8f6cf5", modifiers: "Bold"))),
                (kind: Text(" ── "), style: (fg: "#465577")),
                (kind: Property(Song(Album)),
                 style: (fg: "#ff9ecb"),
                 default: (kind: Text("Unknown Album"), style: (fg: "#8f6cf5"))),
            ],
            align: Center,
            scroll_speed: 2,
        )),

        "elapsed_and_bitrate": Pane(Property(
            content: [
                (kind: Property(Status(Elapsed)), style: (fg: "#7afcff")),
                (kind: Text(" / "), style: (fg: "#465577")),
                (kind: Property(Status(Duration)), style: (fg: "#7afcff")),
                (kind: Group([
                    (kind: Text(" ("), style: (fg: "#465577")),
                    (kind: Property(Status(Bitrate)), style: (fg: "#8f6cf5")),
                    (kind: Text(" kbps)"), style: (fg: "#465577")),
                ])),
            ],
            align: Left,
        )),

        "states": Pane(Property(
            content: [
                (kind: Property(Status(RepeatV2(
                    on_label:  " 󰑖 ",
                    off_label: " 󰑖 ",
                    on_style:  (fg: "#7afcff", modifiers: "Bold"),
                    off_style: (fg: "#465577", modifiers: "Dim"),
                )))),
                (kind: Property(Status(RandomV2(
                    on_label:  " 󰒝 ",
                    off_label: " 󰒝 ",
                    on_style:  (fg: "#ff739e", modifiers: "Bold"),
                    off_style: (fg: "#465577", modifiers: "Dim"),
                )))),
                (kind: Property(Status(SingleV2(
                    on_label:      " 󰑘 ",
                    off_label:     " 󰑘 ",
                    oneshot_label: " 󰑘 ",
                    on_style:      (fg: "#ff9ecb", modifiers: "Bold"),
                    off_style:     (fg: "#465577", modifiers: "Dim"),
                    oneshot_style: (fg: "#ff3270", modifiers: "Bold"),
                )))),
                (kind: Property(Status(ConsumeV2(
                    on_label:      " 󰮯 ",
                    off_label:     " 󰮯 ",
                    oneshot_label: " 󰮯 ",
                    on_style:      (fg: "#40c4ff", modifiers: "Bold"),
                    off_style:     (fg: "#465577", modifiers: "Dim"),
                    oneshot_style: (fg: "#ff3270", modifiers: "Dim"),
                )))),
                (kind: Text(" / "), style: (fg: "#465577")),
                (kind: Property(Status(QueueTimeRemaining(separator: " "))),
                 style: (fg: "#ff739e", modifiers: "Bold")),
            ],
            align: Right,
        )),

        "top_row": Split(
            direction: Horizontal,
            panes: [
                (size: "23",   pane: Component("state")),
                (size: "100%", borders: "LEFT | RIGHT", pane: Component("title")),
                (size: "23",   pane: Component("volume")),
            ],
        ),

        "bottom_row": Split(
            direction: Horizontal,
            panes: [
                (size: "23",   pane: Component("elapsed_and_bitrate")),
                (size: "100%", borders: "LEFT | RIGHT", pane: Component("artist_album")),
                (size: "23",   pane: Component("states")),
            ],
        ),

        "header": Split(
            direction: Vertical,
            panes: [
                (size: "1", pane: Component("top_row")),
                (size: "1", pane: Component("bottom_row")),
            ],
        ),

        "progress_bar": Split(
            direction: Horizontal,
            panes: [
                (size: "3", pane: Pane(Property(
                    content: [(kind: Property(Status(StateV2(
                        playing_label: " ▶ ",
                        paused_label:  " ❚❚",
                        stopped_label: " ■ ",
                        playing_style: (fg: "#7afcff", modifiers: "Bold"),
                        paused_style:  (fg: "#ff739e", modifiers: "Bold"),
                        stopped_style: (fg: "#ff3270", modifiers: "Bold"),
                    ))))],
                    align: Left,
                ))),
                (size: "100%", pane: Pane(ProgressBar)),
                (size: "13", pane: Pane(Property(
                    content: [
                        (kind: Property(Status(Elapsed)), style: (fg: "#7afcff")),
                        (kind: Text(" / "), style: (fg: "#465577")),
                        (kind: Property(Status(Duration)), style: (fg: "#ff9ecb")),
                    ],
                    align: Right,
                ))),
            ],
        ),
    },

    layout: Split(
        direction: Vertical,
        panes: [
            (size: "4",    borders: "ALL", pane: Component("header")),
            (size: "3",    borders: "ALL", pane: Pane(Tabs)),
            (size: "100%", borders: "ALL", pane: Pane(TabContent)),
            (size: "3",    borders: "ALL", pane: Component("progress_bar")),
        ],
    ),

    symbols: (
        song:       "♪",
        dir:        "▸",
        playlist:   "♫",
        marker:     "▶",
        ellipsis:   "…",
        song_style: (fg: "#ff739e"),
        dir_style:  (fg: "#7afcff"),
    ),

    progress_bar: (
        symbols:       ["", "▰", "◆", "▱", ""],
        track_style:   (fg: "#1b2a4a"),
        elapsed_style: (fg: "#ff3270"),
        thumb_style:   (fg: "#40c4ff", bg: "#1b2a4a"),
    ),

    scrollbar: (
        symbols:     ["│", "█", "▲", "▼"],
        track_style: (fg: "#1b2a4a"),
        ends_style:  (fg: "#8f6cf5"),
        thumb_style: (fg: "#ff3270"),
    ),

    browser_column_widths: [20, 38, 42],

    tab_bar: (
        active_style:   (fg: "#101418", bg: "#ff3270", modifiers: "Bold"),
        inactive_style: (fg: "#8f6cf5"),
    ),

    highlighted_item_style: (fg: "#7afcff", modifiers: "Bold"),
    current_item_style:     (fg: "#101418", bg: "#ff739e", modifiers: "Bold"),
    borders_style:          (fg: "#8f6cf5"),
    highlight_border_style: (fg: "#ff3270", modifiers: "Bold"),

    song_table_album_separator: None,
    song_table_format: [
        (
            prop: (kind: Property(Position), style: (fg: "#465577")),
            width: "3",
            alignment: Right,
            label: "#",
        ),
        (
            prop: (kind: Property(Other("albumartist")),
                   style: (fg: "#ff3270", modifiers: "Bold"),
                   default: (kind: Property(Artist),
                             style: (fg: "#ff3270", modifiers: "Bold"),
                             default: (kind: Text("—"), style: (fg: "#465577")))),
            width: "20%",
            label: "Artist",
        ),
        (
            prop: (kind: Property(Title),
                   style: (fg: "#ff9ecb"),
                   default: (kind: Text("—"), style: (fg: "#465577"))),
            width: "35%",
            label: "Title",
        ),
        (
            prop: (kind: Property(Album),
                   style: (fg: "#8f6cf5"),
                   default: (kind: Text("—"), style: (fg: "#465577"))),
            width: "37%",
            label: "Album",
        ),
        (
            prop: (kind: Property(Duration),
                   style: (fg: "#7afcff"),
                   default: (kind: Text("—"), style: (fg: "#465577"))),
            width: "5",
            alignment: Right,
            label: "Time",
        ),
    ],

    header: (rows: []),
)
