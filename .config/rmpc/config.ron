#![enable(implicit_some)]
#![enable(unwrap_newtypes)]
#![enable(unwrap_variant_newtypes)]
(
    address: "/home/mandest/.local/share/mpd/socket",
    cache_dir: Some("/home/mandest/.cache/rmpc"),
    theme: "vaporwave",

    volume_step: 5,
    scrolloff: 2,
    max_fps: 60,
    wrap_navigation: true,
    status_update_interval_ms: 1000,
    select_current_song_on_change: true,
    center_current_song_on_change: false,
    enable_mouse: true,
    enable_config_hot_reload: true,

    album_art: (
        method: Auto,
        max_size_px: (width: 0, height: 0),
        vertical_align: Top,
        horizontal_align: Center,
    ),

    cava: (
        framerate: 60,
        autosens: true,
        sensitivity: 80,
        input: (
            method: Fifo,
            source: "/tmp/mpd.fifo",
            sample_rate: 44100,
            channels: 2,
            samble_bits: 16,
        ),
        smoothing: (
            noise_reduction: 88,
            monstercat: true,
            waves: false,
        ),
    ),

    search: (
        case_sensitive: false,
        mode: Contains,
        tags: [
            (value: "any",         label: "Any Tag"),
            (value: "artist",      label: "Artist"),
            (value: "album",       label: "Album"),
            (value: "albumartist", label: "Album Artist"),
            (value: "title",       label: "Title"),
        ],
    ),

    tabs: [
        (
            name: "Queue",
            border_type: None,
            pane: Split(
                direction: Horizontal,
                panes: [
                    (
                        size: "30%",
                        borders: "RIGHT",
                        pane: Split(
                            direction: Vertical,
                            panes: [
                                (size: "100%", pane: Split(
                                    direction: Vertical,
                                    panes: [
                                        (size: "1", pane: Pane(Property(
                                            content: [(kind: Text("◆ T R A C K   I N F O ◆"),
                                                       style: (fg: "#ff2a6d", modifiers: "Bold"))],
                                            align: Center,
                                        ))),
                                        (size: "1", pane: Pane(Property(
                                            content: [(kind: Text(""))], align: Center,
                                        ))),
                                        (size: "1", pane: Pane(Property(
                                            content: [
                                                (kind: Text("  year      "), style: (fg: "#5b2a86")),
                                                (kind: Property(Song(Other("date"))),
                                                 style: (fg: "#7afcff", modifiers: "Bold"),
                                                 default: (kind: Text("—"), style: (fg: "#5b2a86"))),
                                            ],
                                            align: Left,
                                        ))),
                                        (size: "1", pane: Pane(Property(
                                            content: [
                                                (kind: Text("  genre     "), style: (fg: "#5b2a86")),
                                                (kind: Property(Song(Other("genre"))),
                                                 style: (fg: "#ff9ecb"),
                                                 default: (kind: Text("—"), style: (fg: "#5b2a86"))),
                                            ],
                                            align: Left,
                                        ))),
                                        (size: "1", pane: Pane(Property(
                                            content: [
                                                (kind: Text("  composer  "), style: (fg: "#5b2a86")),
                                                (kind: Property(Song(Other("composer"))),
                                                 style: (fg: "#ff9ecb"),
                                                 default: (kind: Text("—"), style: (fg: "#5b2a86"))),
                                            ],
                                            align: Left,
                                        ))),
                                        (size: "1", pane: Pane(Property(
                                            content: [(kind: Text(""))], align: Center,
                                        ))),
                                        (size: "1", pane: Pane(Property(
                                            content: [
                                                (kind: Text("  rate      "), style: (fg: "#5b2a86")),
                                                (kind: Property(Status(Bitrate)),
                                                 style: (fg: "#00e5ff", modifiers: "Bold")),
                                                (kind: Text(" kbps"), style: (fg: "#5b2a86")),
                                            ],
                                            align: Left,
                                        ))),
                                    ],
                                )),
                                (size: "12", borders: "TOP", pane: Pane(AlbumArt)),
                            ],
                        ),
                    ),
                    (
                        size: "70%",
                        pane: Split(
                            direction: Vertical,
                            panes: [
                                (size: "100%", pane: Pane(Queue)),
                                (size: "12", borders: "TOP", pane: Pane(Cava)),
                            ],
                        ),
                    ),
                ],
            ),
        ),
        (name: "Directories",   border_type: None, pane: Pane(Directories)),
        (name: "Artists",       border_type: None, pane: Pane(Artists)),
        (name: "Album Artists", border_type: None, pane: Pane(AlbumArtists)),
        (name: "Albums",        border_type: None, pane: Pane(Albums)),
        (name: "Playlists",     border_type: None, pane: Pane(Playlists)),
        (name: "Search",        border_type: None, pane: Pane(Search)),
    ],
)
